# --- APPLICATION CONFIG ---
APP_NAME=green-login-be
APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev
# --- DATABASE (MySQL) ---
# Format: jdbc:mysql://<host>:<port>/<db_name>
DB_HOST=localhost
DB_URL=jdbc:mysql://localhost:3306/db_green?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PORT=3306
DB_NAME=db_green
DB_PASSWORD=912001
# --- SECURITY (JWT) ---
# Chuỗi secret nên dài và ngẫu nhiên (tối thiểu 32-64 ký tự)
JWT_SECRET=your_very_secret_and_long_key_for_jwt_signing_32_chars_min
# Expiration: 3600000ms = 1 giờ
JWT_EXPIRATION=3600000
# --- FLYWAY (Migration) ---
FLYWAY_ENABLED=true

# --- CORS (Cross-Origin) ---
# Các biến này được ánh xạ tới các property Spring: cors.allowed-origins, cors.allowed-methods,
# cors.allowed-headers, cors.exposed-headers, cors.allow-credentials
# Ví dụ: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://green-logix-fe.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=authorization,content-type,x-auth-token
CORS_EXPOSED_HEADERS=x-auth-token
CORS_ALLOW_CREDENTIALS=true

# --- MAIL CONFIG ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- VNPAY CONFIG ---
VNPAY_TMN_CODE=QXST4W8X
VNPAY_HASH_SECRET=77BXF1LE6HAC9KHPBI7QL20GV96GB87P
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/vnpay/payment-callback
VNPAY_FRONTEND_RESULT_URL=http://localhost:5173/payment-result
